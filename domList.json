{
    "_comment": "Claude.ai 新版 React SPA 注册页面选择器（2025-06）",
    "_note": "如果失效，运行 python discover_dom.py 重新探测",

    "mailInput": "//input[@type='email'] | //input[@type='text' and contains(@placeholder,'mail')] | //input[contains(@name,'mail')] | //input[contains(@id,'mail')]",
    "nextMailButton": "//button[@type='submit'] | //button[contains(text(),'Continue')] | //button[contains(text(),'continue')] | //button[contains(.,'Continue with email')]",

    "jumpPageYears": "//input[@type='checkbox']",
    "jumpPageYearsNext": "//button[contains(@type,'submit')]",
    "timeOrOneButton": "//button[contains(text(),'Continue') or contains(text(),'Next')]",
    "freeButton": "//button[contains(text(),'Free') or contains(text(),'Continue') or contains(text(),'Get started')]",
    "iUnderstandButton": "//button[contains(text(),'Understand') or contains(text(),'Agree') or contains(text(),'Continue') or contains(text(),'Accept')]",
    "settingsName": "//input[@type='text']",
    "settingsNameNext": "//button[@type='submit']",
    "setCodding": "//button[contains(text(),'Code') or contains(text(),'Development')]",
    "setCoddingNext": "//button[@type='submit']",
    "iEndMy": "//button[contains(text(),'Skip') or contains(text(),'End')]",
    "isPheon": "//input[@type='checkbox']",

    "_fallback": "mailInput=document.querySelector('input[type=email]'); nextMailButton=document.querySelector('button[type=submit]')"
}
